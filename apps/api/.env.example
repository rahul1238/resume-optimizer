APP_NAME="Resume Optimizer API"
APP_ENV="development"
CORS_ALLOWED_ORIGINS='["http://localhost:3000"]'
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_SERVICE_ACCOUNT_PATH="/absolute/path/to/firebase-service-account.json"
FIREBASE_WEB_API_KEY="your-firebase-web-api-key"
FIREBASE_CHECK_REVOKED_TOKENS=true
R2_ENDPOINT_URL="https://your-account-id.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="resume-optimizer"
R2_UPLOAD_TIMEOUT_SECONDS=30
MAX_RESUME_UPLOAD_BYTES=5242880
MAX_DOCX_UNCOMPRESSED_BYTES=20971520
GEMINI_API_KEY="your-google-ai-studio-api-key"
GEMINI_MODEL="gemini-3.5-flash"
GEMINI_TIMEOUT_SECONDS=60
MAX_JOB_DESCRIPTION_CHARACTERS=30000
